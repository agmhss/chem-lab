<!DOCTYPE html>
<html lang="ta">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Hydrated Salts Lab | நீரேறிய உப்புகள்</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <style>
        body { background-color: #fdfefe; font-family: 'Segoe UI', sans-serif; }
        .lab-bench { background: #e0e0e0; height: 15px; width: 100%; margin-top: 150px; border-radius: 5px; }
        
        /* Test Tube Styling */
        .test-tube-container { position: relative; height: 250px; margin-top: 50px; }
        .test-tube {
            width: 40px; height: 180px;
            border: 3px solid #ccc;
            border-top: none;
            border-radius: 0 0 20px 20px;
            position: absolute;
            left: 50%; transform: translateX(-50%);
            background: rgba(255, 255, 255, 0.5);
            overflow: hidden;
            z-index: 2;
        }
        .salt {
            position: absolute;
            bottom: 0; width: 100%;
            height: 40px;
            transition: background 2s ease, filter 1s ease;
        }
        
        /* Burner Styling */
        .burner { width: 60px; height: 50px; background: #555; margin: 0 auto; position: relative; border-radius: 5px 5px 0 0; }
        .flame {
            width: 20px; height: 35px;
            background: orange;
            border-radius: 50% 50% 20% 20%;
            position: absolute;
            top: -35px; left: 20px;
            display: none;
            animation: flicker 0.1s infinite;
        }
        @keyframes flicker {
            0% { transform: scale(1); opacity: 0.8; }
            100% { transform: scale(1.1); opacity: 1; }
        }

        /* Steam Animation */
        .steam {
            position: absolute; top: -20px; left: 50%;
            width: 10px; height: 10px; background: rgba(200,200,200,0.5);
            border-radius: 50%; display: none;
        }
    </style>
</head>
<body>

<div class="container py-5 text-center">
    <h2 class="mb-4" data-ta="நீரேறிய உப்புகள் சோதனை" data-en="Hydrated Salts Experiment">நீரேறிய உப்புகள் சோதனை</h2>
    <p class="text-muted">காப்பர் சல்பேட் படிகங்களைச் சூடாக்கி நீர் மூலக்கூறுகளை அகற்றுதல்.</p>

    <div class="row justify-content-center">
        <div class="col-md-6 border bg-white p-5 rounded shadow">
            
            <div class="test-tube-container">
                <div class="test-tube">
                    <div id="saltColor" class="salt" style="background-color: #0000ff;"></div>
                </div>
                <div id="steam" class="steam"></div>
            </div>

            <div class="burner">
                <div id="flame" class="flame"></div>
            </div>
            <div class="lab-bench"></div>

            <div class="mt-5">
                <button id="heatBtn" class="btn btn-danger px-4" onclick="startHeating()">சூடாக்கு (Heat)</button>
                <button id="addWaterBtn" class="btn btn-primary px-4 d-none" onclick="addWater()">நீர் சேர் (Add Water)</button>
                <button class="btn btn-outline-secondary px-4" onclick="resetLab()">Reset</button>
            </div>

            <div id="msg" class="alert alert-info mt-4">
                நீல நிற காப்பர் சல்பேட் படிகங்கள் தயாராக உள்ளன.
            </div>
        </div>
    </div>
    
    <div class="mt-4">
        <p>$$CuSO_4 \cdot 5H_2O \xrightarrow{\Delta} CuSO_4 + 5H_2O$$</p>
    </div>
</div>

<script>
    function startHeating() {
        document.getElementById('flame').style.display = 'block';
        document.getElementById('msg').innerText = "சூடாக்கப்படுகிறது... நீர் மூலக்கூறுகள் வெளியேறுகின்றன.";
        document.getElementById('heatBtn').disabled = true;

        // Change color slowly
        setTimeout(() => {
            document.getElementById('saltColor').style.backgroundColor = '#f0f0f0'; // White
            document.getElementById('flame').style.display = 'none';
            document.getElementById('msg').className = "alert alert-warning mt-4";
            document.getElementById('msg').innerText = "வெப்பத்தால் நீர் வெளியேறி, உப்பு வெண்மையாக மாறியது (Anhydrous).";
            document.getElementById('addWaterBtn').classList.remove('d-none');
        }, 3000);
    }

    function addWater() {
        document.getElementById('msg').innerText = "நீர் சேர்க்கப்படுகிறது...";
        setTimeout(() => {
            document.getElementById('saltColor').style.backgroundColor = '#0000ff'; // Back to Blue
            document.getElementById('msg').className = "alert alert-success mt-4";
            document.getElementById('msg').innerText = "மீண்டும் நீர் சேர்த்தவுடன் படிக நீர் உருவாகி நீல நிறம் திரும்பியது!";
            document.getElementById('addWaterBtn').classList.add('d-none');
        }, 1500);
    }

    function resetLab() {
        location.reload();
    }
</script>

</body>
</html>
